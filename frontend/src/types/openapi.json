  "components": {
    "schemas": {
      "CrossRefInfo": {
        "properties": {
          "ien": {
            "type": "string",
            "title": "Ien"
          },
          "file_number": {
            "type": "number",
            "title": "File Number"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "xref_type": {
            "type": "string",
            "title": "Xref Type",
            "default": ""
          },
          "description": {
            "type": "string",
            "title": "Description",
            "default": ""
          }
        },
        "type": "object",
        "required": [
          "ien",
          "file_number",
          "name"
        ],
        "title": "CrossRefInfo",
        "description": "One cross-reference on a FileMan file."
      },
      "Entry": {
        "properties": {
          "file_number": {
            "type": "number",
            "title": "File Number"
          },
          "ien": {
            "type": "string",
            "title": "Ien"
          },
          "fields": {
            "additionalProperties": {
              "$ref": "#/components/schemas/FieldValue"
            },
            "type": "object",
            "title": "Fields"
          }
        },
        "type": "object",
        "required": [
          "file_number",
          "ien"
        ],
        "title": "Entry",
        "description": "One FileMan entry (row).\n\n``fields`` is keyed by FileMan field number \u2014 callers usually know\nthe numbers ahead of time (they requested them via the ``fields``\nparam of DDR GETS or DDR LISTER). When we list entries with a\ndefault field set (just .01), ``fields`` holds just that field."
      },
      "EntryPage": {
        "properties": {
          "file_number": {
            "type": "number",
            "title": "File Number"
          },
          "entries": {
            "items": {
              "$ref": "#/components/schemas/Entry"
            },
            "type": "array",
            "title": "Entries"
          },
          "next_cursor": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Next Cursor"
          }
        },
        "type": "object",
        "required": [
          "file_number",
          "entries"
        ],
        "title": "EntryPage",
        "description": "A paginated slice of entries + a cursor for the next page.\n\n``next_cursor`` is the last ``external_value`` (usually the .01\nfield) from this page \u2014 pass it back as ``cursor`` to fetch the\nnext page. ``None`` when the page is the last."
      },
      "FieldDef": {
        "properties": {
          "file_number": {
            "type": "number",
            "title": "File Number"
          },
          "field_number": {
            "type": "number",
            "title": "Field Number"
          },
          "label": {
            "type": "string",
            "title": "Label"
          },
          "type": {
            "$ref": "#/components/schemas/TypeSpec"
          },
          "title": {
            "type": "string",
            "title": "Title",
            "default": ""
          },
          "storage": {
            "type": "string",
            "title": "Storage",
            "default": ""
          },
          "input_transform": {
            "type": "string",
            "title": "Input Transform",
            "default": ""
          },
          "help_prompt": {
            "type": "string",
            "title": "Help Prompt",
            "default": ""
          },
          "description": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Description"
          },
          "set_values": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object",
            "title": "Set Values"
          }
        },
        "type": "object",
        "required": [
          "file_number",
          "field_number",
          "label",
          "type"
        ],
        "title": "FieldDef",
        "description": "One field in a FileMan file."
      },
      "FieldValue": {
        "properties": {
          "field_number": {
            "type": "number",
            "title": "Field Number"
          },
          "value": {
            "type": "string",
            "title": "Value"
          },
          "is_external": {
            "type": "boolean",
            "title": "Is External",
            "default": true
          }
        },
        "type": "object",
        "required": [
          "field_number",
          "value"
        ],
        "title": "FieldValue",
        "description": "One field value on an entry \u2014 external (resolved) form by default.\n\nFLAGS=\"E\" on DDR GETS ENTRY DATA returns external form (dates\nrendered, pointers resolved, set codes labeled). We never see the\ninternal form unless the caller explicitly asked for it.\nSee LESSONS-LEARNED L18."
      },
      "FileDef": {
        "properties": {
          "file_number": {
            "type": "number",
            "title": "File Number"
          },
          "label": {
            "type": "string",
            "title": "Label"
          },
          "global_root": {
            "type": "string",
            "title": "Global Root"
          },
          "package": {
            "type": "string",
            "title": "Package",
            "default": ""
          },
          "description": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Description"
          },
          "fields": {
            "additionalProperties": {
              "$ref": "#/components/schemas/FieldDef"
            },
            "type": "object",
            "title": "Fields"
          }
        },
        "type": "object",
        "required": [
          "file_number",
          "label",
          "global_root"
        ],
        "title": "FileDef",
        "description": "One FileMan file's header + field list."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "PackageDef": {
        "properties": {
          "ien": {
            "type": "string",
            "title": "Ien"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "prefix": {
            "type": "string",
            "title": "Prefix",
            "default": ""
          },
          "short_description": {
            "type": "string",
            "title": "Short Description",
            "default": ""
          },
          "files": {
            "items": {
              "type": "number"
            },
            "type": "array",
            "title": "Files"
          }
        },
        "type": "object",
        "required": [
          "ien",
          "name"
        ],
        "title": "PackageDef",
        "description": "One PACKAGE entry from file 9.4.\n\n``prefix`` is the M namespace (e.g. ``XU``, ``OR``). ``files`` is\npopulated only when the caller drills into the FILE subfile\n(``^DIC(9.4, IEN, 4, ...)``) \u2014 in a basic listing it's empty.\nLESSONS-LEARNED L12 notes that some sites ship a PACKAGE entry\nwith a blank prefix; that's a data-quality issue, not a bug."
      },
      "SessionInfo": {
        "properties": {
          "duz": {
            "type": "string",
            "title": "Duz"
          },
          "user_name": {
            "type": "string",
            "title": "User Name"
          },
          "site_id": {
            "type": "string",
            "title": "Site Id"
          },
          "uci": {
            "type": "string",
            "title": "Uci"
          },
          "app_context": {
            "type": "string",
            "title": "App Context"
          }
        },
        "type": "object",
        "required": [
          "duz",
          "user_name",
          "site_id",
          "uci",
          "app_context"
        ],
        "title": "SessionInfo"
      },
      "SignonRequest": {
        "properties": {
          "access": {
            "type": "string",
            "title": "Access"
          },
          "verify": {
            "type": "string",
            "title": "Verify"
          },
